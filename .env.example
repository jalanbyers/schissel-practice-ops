# Auth0 (API — Fastify)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.schissel.app

# Auth0 (Dashboard — Next.js @auth0/nextjs-auth0)
AUTH0_CLIENT_ID=your-app-client-id
AUTH0_CLIENT_SECRET=your-app-client-secret
# 32+ random bytes: openssl rand -hex 32
AUTH0_SECRET=replace-with-32-plus-random-bytes
# Your app's public URL (no trailing slash)
APP_BASE_URL=http://localhost:3000

# Demo / local development — anonymous access to the dashboard.
#
# Server-only ON PURPOSE. This governs an AUTH BYPASS: when true, middleware
# and the dashboard layout skip Auth0 entirely. It is deliberately not keyed on
# NEXT_PUBLIC_USE_MOCK, which is client-visible — a client-settable flag must
# never control authentication.
#
# Set it only where the deployment genuinely serves synthetic data with no real
# users. Leave it unset anywhere real.
DEMO_ALLOW_ANONYMOUS=false

# Client-visible. Controls DATA mocking in the dashboard hooks only — the UI
# renders seeded fixtures instead of calling the API. Has no effect on auth.
NEXT_PUBLIC_USE_MOCK=false

# Postgres
DATABASE_URL=postgres://schissel:schissel@localhost:5432/schissel

# Server
PORT=3001
