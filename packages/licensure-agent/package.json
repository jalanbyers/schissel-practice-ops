{
  "name": "@schissel/licensure-agent",
  "version": "0.0.1",
  "description": "Licensure analyst agent (ADK) \u2014 synthetic data only, not cleared for production traffic.",
  "type": "module",
  "main": "app/agent.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && npx @google/adk-devtools web -h localhost dist/agent.js",
    "run": "tsc && npx @google/adk-devtools run dist/agent.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "@google/adk-devtools": "^0.3.0",
    "zod": "^4.2.1"
  },
  "private": true
}
